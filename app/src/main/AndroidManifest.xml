<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Required for DistractionEngine — user must grant via Settings > Special App Access > Usage Access -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Launcher permissions -->
    <uses-permission android:name="android.permission.BIND_APPWIDGET" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-permission android:name="android.permission.EXPAND_STATUS_BAR" />

    <!-- Icon pack discovery -->
    <queries>
        <intent>
            <action android:name="org.adw.launcher.THEMES" />
        </intent>
    </queries>

    <application
        android:name=".NeuroFlowApplication"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NeuroFlow">

        <!-- Disable default WorkManager initializer so HiltWorkerFactory can be used -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:taskAffinity="com.neuroflow.app.main"
            android:launchMode="singleTask"
            android:theme="@style/Theme.NeuroFlow">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Launcher Activity -->
        <activity
            android:name=".presentation.launcher.LauncherActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:stateNotNeeded="true"
            android:excludeFromRecents="true"
            android:clearTaskOnLaunch="true"
            android:enableOnBackInvokedCallback="false"
            android:theme="@style/Theme.Launcher.Transparent">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Reschedule workers after device reboot -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- Launcher keepalive alarm restart receiver -->
        <receiver
            android:name=".presentation.launcher.service.LauncherKeepAliveAlarmReceiver"
            android:exported="false" />

        <!-- Handles snooze action from autonomy nudge notification (no app open needed) -->
        <receiver
            android:name=".receiver.NudgeSnoozeReceiver"
            android:exported="false" />

           <!-- Device admin receiver used for fully managed device-owner provisioning -->
        <receiver
            android:name=".receiver.DeviceAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
                <action android:name="android.app.action.PROFILE_PROVISIONING_COMPLETE" />
            </intent-filter>
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_policy" />
        </receiver>

        <!-- FocusWidget AppWidget provider -->
        <receiver
            android:name=".presentation.widget.FocusWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_focus_info" />
        </receiver>

        <!-- Hilt WorkManager workers -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="shortService"
            tools:node="merge" />

        <!-- Persistent launcher keepalive foreground service -->
        <service
            android:name=".presentation.launcher.service.LauncherKeepAliveService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="App process keepalive and restart watchdog" />
        </service>

        <!-- Notification Badge Service -->
        <service
            android:name=".presentation.launcher.data.NotificationBadgeService"
            android:exported="false"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Hyper Focus: blocking overlay activity -->
        <activity
            android:name=".presentation.launcher.hyperfocus.HyperFocusActivity"
            android:launchMode="singleTask"
            android:taskAffinity="com.neuroflow.app.hyperfocus"
            android:excludeFromRecents="true"
            android:exported="false"
            android:enableOnBackInvokedCallback="false"
            android:theme="@style/Theme.NeuroFlow" />

        <!-- Hyper Focus: accessibility service for app blocking -->
        <service
            android:name=".presentation.launcher.hyperfocus.service.AppBlockingService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Hyper Focus: foreground timer service for unlock countdowns -->
        <service
            android:name=".presentation.launcher.hyperfocus.service.UnlockTimerService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Unlock countdown timer for focus session" />
        </service>

        <!-- Hyper Focus: foreground monitor service to keep session active -->
        <service
            android:name=".presentation.launcher.hyperfocus.service.HyperFocusMonitorService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Focus session monitoring" />
        </service>

    </application>

</manifest>
