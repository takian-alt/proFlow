<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NeuroFlow" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Transparent launcher theme that shows system wallpaper -->
    <style name="Theme.Launcher.Transparent" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <!-- Transparent nav bar so wallpaper shows through -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <!-- Light nav bar = dark (visible) buttons on light wallpapers -->
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
